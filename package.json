{
  "name": "aicad",
  "private": true,
  "version": "0.1.0",
  "description": "Forgent3D monorepo",
  "scripts": {
    "dev": "pnpm --filter forgent3d dev",
    "dev:cloud": "pnpm --filter @forgent3d/cloud dev",
    "dev:renderer": "pnpm --filter forgent3d dev:renderer",
    "dev:electron": "pnpm --filter forgent3d dev:electron",
    "dev:electron:watch": "pnpm --filter forgent3d dev:electron:watch",
    "test": "pnpm --filter @forgent3d/shared test",
    "test:shared": "pnpm --filter @forgent3d/shared test",
    "build:shared": "pnpm --filter @forgent3d/shared build",
    "build:runtime": "pnpm --filter @forgent3d/cad-runtime build",
    "postinstall": "pnpm run build:runtime",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm --filter forgent3d build",
    "build:renderer": "pnpm --filter forgent3d build:renderer",
    "build:electron": "pnpm --filter forgent3d build:electron",
    "build:runner": "pnpm --filter forgent3d build:runner",
    "start": "pnpm --filter forgent3d start",
    "mcp:curl-test": "pnpm --filter forgent3d mcp:curl-test",
    "rebuild:native": "pnpm --filter forgent3d rebuild:native"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty",
      "better-sqlite3",
      "sharp",
      "workerd",
      "@forgent3d/cad-runtime"
    ],
    "overrides": {
      "@forgent3d/cad-runtime": "workspace:*"
    }
  }
}
