{
  "name": "forgent3d",
  "version": "0.1.0",
  "private": true,
  "description": "Forgent3D - watch build123d Python changes and render 3D in real time",
  "main": "dist-electron/electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev:renderer": "vite",
    "build:electron": "pnpm --filter @forgent3d/shared run build && pnpm exec tsc -p tsconfig.electron.json",
    "dev:electron": "pnpm run build:electron && wait-on tcp:7788 && cross-env NODE_ENV=development electron .",
    "dev:electron:watch": "pnpm run build:electron && concurrently -k -n TSC,ELECTRON -c blue,magenta \"pnpm exec tsc -p tsconfig.electron.json -w --preserveWatchOutput\" \"wait-on tcp:7788 && cross-env NODE_ENV=development electronmon .\"",
    "dev": "concurrently -k -n RENDERER,ELECTRON -c cyan,magenta \"pnpm:dev:renderer\" \"pnpm:dev:electron\"",
    "typecheck": "pnpm exec tsc --noEmit && pnpm exec tsc -p tsconfig.electron.json --noEmit",
    "build:renderer": "vite build",
    "build:runner": "node scripts/build-embedded-runner.js",
    "start": "pnpm run build:electron && electron .",
    "mcp:curl-test": "bash scripts/mcp-curl-test.sh",
    "build": "pnpm run build:renderer && pnpm run build:electron && pnpm run build:runner && electron-builder",
    "rebuild:native": "electron-rebuild -f -w node-pty"
  },
  "keywords": [
    "electron",
    "cad",
    "build123d",
    "three.js",
    "cursor-ai"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forgent3d/forgent3d.git"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/three": "^0.184.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electronmon": "^2.0.4",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@forgent3d/cad-runtime": "workspace:*",
    "@forgent3d/shared": "workspace:*",
    "@forgent3d/viewer": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mujoco/mujoco": "^3.8.0",
    "@types/node": "^25.6.0",
    "@xmldom/xmldom": "^0.9.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^7.0.0",
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.3.9",
    "node-pty": "^1.1.0",
    "occt-import-js": "^0.0.23",
    "three": "^0.168.0",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.forgent3d.app",
    "productName": "Forgent3D",
    "icon": "assets/images/logo.png",
    "win": {
      "icon": "assets/images/logo.png",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "assets/images/logo.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "notarize": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "forgent3d",
        "repo": "forgent3d"
      }
    ],
    "linux": {
      "icon": "assets/images/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "displayLanguageSelector": true,
      "multiLanguageInstaller": true,
      "installerLanguages": [
        "en_US",
        "zh_CN"
      ]
    },
    "files": [
      "dist-electron/electron/**",
      "electron/skills/**",
      "dist/**",
      "assets/**",
      "package.json",
      {
        "from": "node_modules/three/examples/jsm",
        "to": "node_modules/three/examples/jsm",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "vendor/export-runner",
        "to": "export-runner",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@forgent3d/cad-runtime/python/skill-helpers",
        "to": "skill-helpers",
        "filter": [
          "*.py"
        ]
      },
      {
        "from": "../cloud/lib/aicad-agent/skills/archetypes",
        "to": "cloud-agent-skills/archetypes",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "electronmon": {
    "patterns": [
      "electron/**",
      "dist-electron/**",
      "!node_modules/**",
      "!dist/**"
    ]
  }
}
