{
  "name": "@forgent3d/viewer",
  "version": "1.1.0",
  "description": "Shared browser-only Forgent3D 3D viewer (Three.js + BREP/GLB/STL/MJCF loaders)",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./glb": {
      "types": "./src/viewer-glb.ts",
      "import": "./src/viewer-glb.ts",
      "default": "./src/viewer-glb.ts"
    },
    "./brep": {
      "types": "./src/viewer-brep.ts",
      "import": "./src/viewer-brep.ts",
      "default": "./src/viewer-brep.ts"
    }
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "three": "^0.168.0"
  },
  "dependencies": {
    "@mujoco/mujoco": "^3.8.0",
    "occt-import-js": "^0.0.23"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "three": "^0.168.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0"
  }
}
